  transition: opacity 240ms ease, transform 320ms cubic-bezier(.18,.8,.22,1); pointer-events: none;
}
.screen-loading.is-complete .loading-complete-pill { opacity: 1; transform: translate(-50%,0) scale(1); }
.ambient-leaf, .burst-leaf {
  position: absolute; width: var(--w,24px); height: calc(var(--w,24px) * .46); border-radius: 100% 0 100% 0;
  background: linear-gradient(145deg,rgba(255,255,255,.34),transparent 48%),var(--leaf-color,#9aac64);
  border: 1px solid rgba(116,136,79,.28); filter: drop-shadow(0 4px 4px rgba(42,36,24,.1));
}
.ambient-leaf::after, .burst-leaf::after { content: ""; position: absolute; left: 18%; top: 48%; width: 68%; height: 1px; border-radius: 999px; background: rgba(42,36,24,.18); transform: rotate(-10deg); }
.ambient-leaf { top: -60px; opacity: 0; animation: leaf-fall var(--fall,6s) linear infinite, leaf-sway var(--sway,2s) ease-in-out infinite; animation-delay: var(--delay,0s), calc(var(--delay,0s) * .35); }
.burst-leaf { left: 50%; top: 58%; opacity: 0; transform: translate(-50%,-50%) scale(.4) rotate(0); }
.screen-loading.is-complete .burst-leaf { animation: leaf-burst 1160ms cubic-bezier(.18,.72,.22,1) forwards; animation-delay: var(--burst-delay,0s); }

@keyframes loading-shine { 0% { transform: translateX(-120%); } 58%, 100% { transform: translateX(280%); } }
@keyframes sprout-bob { 0%, 100% { margin-top: 0; } 50% { margin-top: -5px; } }
@keyframes leaf-fall {
  0% { top: -62px; opacity: 0; transform: translateX(0) rotate(0); }
  10%, 84% { opacity: .72; }
  100% { top: calc(100% + 68px); opacity: 0; transform: translateX(var(--drift,46px)) rotate(var(--rot,260deg)); }
}
@keyframes leaf-sway { 0%, 100% { margin-left: calc(var(--sway-x,22px) * -.5); } 50% { margin-left: var(--sway-x,22px); } }
@keyframes leaf-burst {
  0% { opacity: 0; transform: translate(-50%,-50%) scale(.36) rotate(0); }
  10% { opacity: 1; }
  76% { opacity: .9; }
  100% { opacity: 0; transform: translate(calc(-50% + var(--tx,0px)),calc(-50% + var(--ty,-180px))) scale(var(--scale,1)) rotate(var(--r,360deg)); }
}
@keyframes loading-panel-settle {
  0% { opacity: 1; transform: translateY(0) scale(1); }
  42% { opacity: 1; transform: translateY(-8px) scale(1.012); }
  100% { opacity: .28; transform: translateY(18px) scale(.985); }
}

/* ── Exit transition: loading → landing ───────────────────────── */
.screen-loading.is-exiting {
  animation: loadingExit 850ms cubic-bezier(0.4, 0, 0.2, 1) forwards;
}
.screen-loading.is-exiting .screen-loading-bg {
  transition: transform 850ms cubic-bezier(0.4, 0, 0.2, 1), opacity 700ms ease;
  transform: scale(1.12);
  opacity: 0.3;
}
.screen-loading.is-exiting .screen-loading-content {
  animation: loadingContentExit 600ms cubic-bezier(0.4, 0, 0.2, 1) forwards;
}
.screen-loading.is-exiting .loading-complete-pill {
  animation: loadingPillExit 500ms cubic-bezier(0.4, 0, 0.2, 1) forwards;
}
.screen-loading.is-exiting .leaf-layer,
.screen-loading.is-exiting .burst-layer {
  transition: opacity 500ms ease;
  opacity: 0;
}

@keyframes loadingExit {
  0% { opacity: 1; transform: scale(1); filter: blur(0); }
  60% { opacity: 0.6; transform: scale(1.03); filter: blur(2px); }
  100% { opacity: 0; transform: scale(1.06); filter: blur(8px); }
}
@keyframes loadingContentExit {
  0% { opacity: 1; transform: translateY(0); }
  100% { opacity: 0; transform: translateY(-40px); }
}
@keyframes loadingPillExit {
  0% { opacity: 1; transform: translate(-50%, 0) scale(1); }
  100% { opacity: 0; transform: translate(-50%, -20px) scale(0.9); }
}

@media (max-width: 720px) {
  .screen-loading-content { padding: 28px 20px; }
  .loading-copy { padding-top: 22px; }
  .loading-title-row { align-items: flex-start; }
  .loading-logo { width: 48px; height: 48px; font-size: 26px; }
  .loading-title { font-size: 42px; }
  .loading-subtitle { font-size: 15px; }
  .loading-progress-area { padding-bottom: 72px; }
}
@media (prefers-reduced-motion: reduce) {
  .ambient-leaf, .burst-leaf, .loading-progress-fill::after, .loading-progress-tip i { animation: none !important; }
  .ambient-leaf { top: 30%; opacity: .28; }
}
</file>

