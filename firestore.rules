rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /runs/{document} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.score is int
        && request.resource.data.score > 0
        && request.resource.data.score <= 9999
        && request.resource.data.playTimeSec == 180
        && request.resource.data.verified == false;
      allow update, delete: if false;
    }
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.bestScore is int
        && request.resource.data.bestScore >= 0
        && request.resource.data.bestScore <= 9999
        && request.resource.data.totalGamesPlayed is int
        && request.resource.data.totalGamesPlayed >= 0;
      allow delete: if false;
    }
  }
}
