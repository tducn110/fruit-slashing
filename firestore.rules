rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /runs/{document} {
      allow read: if true;
      allow write: if false;
    }
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }
    match /gameSessions/{userId} {
      allow read, write: if false;
    }
  }
}
